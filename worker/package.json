{
  "name": "the-break-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Always-on worker that polls TxLINE for live World Cup match events, detects hydration breaks, and writes rounds to Supabase.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "1.98.4",
    "@supabase/supabase-js": "2.110.6",
    "axios": "^1.7.9",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
