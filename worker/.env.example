# --- Supabase (service role — worker only, never expose to the frontend) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Solana / TxLINE network selection ---
# Use "devnet" for the whole project per the hard constraints.
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Base58 secret key (JSON array or base58 string) of the wallet the worker
# uses to hold the TxLINE entitlement. Fund it with devnet SOL from
# https://faucet.solana.com before first run — the on-chain `subscribe`
# call needs a small amount for tx fees/rent even on the free tier.
WORKER_WALLET_SECRET_KEY=

# --- TxLINE ---
# Devnet hosts per TxLINE's quickstart (https://txline-docs.txodds.com/documentation/quickstart)
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_TOKEN_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
# World Cup free tier service level — confirm the current id in
# https://txline-docs.txodds.com/documentation/worldcup before first run.
TXLINE_SERVICE_LEVEL_ID=1
TXLINE_SUBSCRIPTION_WEEKS=4

# --- Poll tuning ---
POLL_INTERVAL_MS=15000
BREAK_MINUTE_THRESHOLD=20
